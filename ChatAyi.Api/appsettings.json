{
  "Cerebras": {
    "ApiUrl": "https://api.cerebras.ai/v1/chat/completions",
    "DefaultModel": "gpt-oss-120b"
  },
  "Workspace": {
    "Root": "workspace"
  },
  "Memory": {
    "LongTermFile": "MEMORY.md",
    "DailyDir": "memory",
    "Directory": "memory",
    "MaxSnippets": 4,
    "MaxChars": 3500
  },
  "Sessions": {
    "Directory": "sessions"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
